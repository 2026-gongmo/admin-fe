# 베프 Admin Web environment example
# 기본은 Mock 모드이며, http 모드에서는 Spring Boot API 일부를 호출합니다.
# 실제 .env는 로컬에만 만들고 GitHub에 올리지 마세요.

# 예: http://127.0.0.1:18080
VITE_API_BASE_URL=http://127.0.0.1:18080

# mock | http
# mock: 백엔드 없이 프론트 시연
# http: Spring Boot API 일부 연결
VITE_API_MODE=mock

# 데모 시연 편의 옵션입니다.
# http 모드에서 백엔드 재시작으로 메모리 토큰이 사라지면 기본 seed 계정으로 자동 재로그인합니다.
# 실제 운영에서는 false로 두고 refresh token/session 정책을 별도로 구현하세요.
VITE_DEMO_AUTO_LOGIN=true
VITE_DEMO_ADMIN_PASSWORD=onda1234!

# Kakao 지도 JavaScript 키
# 실제 키는 .env.local에만 넣고 GitHub에 올리지 마세요.
VITE_KAKAO_MAP_APP_KEY=

# 학교별 지도 설정
# 실제 파일럿 학교가 정해지면 학교명과 캠퍼스 중심 좌표를 여기에 넣습니다.
VITE_CAMPUS_NAME=베프 대학교 데모 캠퍼스
VITE_CAMPUS_CENTER_LAT=37.58745
VITE_CAMPUS_CENTER_LNG=127.05935
VITE_CAMPUS_MAP_ZOOM=16
